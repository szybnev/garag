# Qdrant
QDRANT_URL=http://localhost:6380
QDRANT_COLLECTION=garag_v1

# LLM provider: openai_compat (LM Studio) or ollama
LLM_PROVIDER=openai_compat

# Ollama (внешний контейнер на хосте)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_JUDGE_MODEL=qwen3.5:35b
OLLAMA_KEEP_ALIVE=30s

# OpenAI-compatible local server (LM Studio)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=zai-org/glm-4.7-flash

# Embedding / reranker
EMBEDDING_PROVIDER=openai_compat
OPENAI_EMBEDDING_BASE_URL=http://localhost:1234/v1
OPENAI_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
EMBEDDING_DIM=1024
BGE_M3_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# BM25 (current golden_set_v1 snapshot: k1=0.8, b=0.5 -> nDCG@10=0.8024)
BM25_K1=0.8
BM25_B=0.5

# Fusion (current golden_set_v1 snapshot: alpha-weighted alpha=0.3 -> nDCG@10=0.7880)
FUSION_METHOD=alpha
FUSION_ALPHA=0.3

# Retrieval
RETRIEVE_TOP_K=20
RERANK_TOP_K=12

# Generation (tuned on 20 golden queries via scripts/tune_gen_params.py)
GEN_TEMPERATURE=0.4
GEN_TOP_P=1.0
GEN_NUM_PREDICT=800
GEN_SEED=42

# Observability
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Guardrails
GUARDRAILS_ENABLED=true
GUARDRAILS_BASE_URL=http://localhost:1234/v1
GUARDRAILS_MODEL=granite-guardian-3.2-5b
GUARDRAILS_TIMEOUT_S=30
GUARDRAILS_FAIL_CLOSED=true
GUARDRAILS_BLOCK_GROUNDEDNESS=false
