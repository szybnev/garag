# Qdrant
QDRANT_URL=http://localhost:6380
QDRANT_COLLECTION=garag_v1

# Ollama (внешний контейнер на хосте)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:14b
OLLAMA_JUDGE_MODEL=qwen3.5:35b
OLLAMA_KEEP_ALIVE=30s

# Embedding / reranker
BGE_M3_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# BM25 (будут перезаписаны после tune_bm25.py)
BM25_K1=1.5
BM25_B=0.75

# Fusion (будет перезаписано после tune_fusion.py)
FUSION_ALPHA=0.5

# Retrieval
RETRIEVE_TOP_K=20
RERANK_TOP_K=5

# Generation
GEN_TEMPERATURE=0.2
GEN_TOP_P=0.9
GEN_NUM_PREDICT=800
GEN_SEED=42

# Observability
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Guardrails
GUARDRAILS_ENABLED=true
